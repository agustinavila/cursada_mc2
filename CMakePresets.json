{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "toolchainFile": "${sourceDir}/cmake/toolchain-arm-none-eabi.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "toolchainFile": "${sourceDir}/cmake/toolchain-arm-none-eabi.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "host-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CURSADA_MC2_ENABLE_HOST_TESTS": "ON"
            }
        },
        {
            "name": "host-debug",
            "displayName": "Host Debug",
            "inherits": "host-base",
            "binaryDir": "${sourceDir}/build/host-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "host-coverage",
            "displayName": "Host Coverage",
            "inherits": "host-base",
            "binaryDir": "${sourceDir}/build/host-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CURSADA_MC2_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "host-debug",
            "configurePreset": "host-debug"
        },
        {
            "name": "host-coverage",
            "configurePreset": "host-coverage"
        }
    ],
    "testPresets": [
        {
            "name": "host-debug",
            "configurePreset": "host-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "host-coverage",
            "configurePreset": "host-coverage",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}

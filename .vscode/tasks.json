{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure [debug]",
            "type": "shell",
            "command": "cmake --preset debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build App [debug]",
            "type": "shell",
            "command": "cmake --build --preset debug --target cursada_mc2_app",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Configure [debug]"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Flash App [debug]",
            "type": "shell",
            "command": "cmake --build --preset debug --target flash_cursada_mc2_app",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build App [debug]"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
